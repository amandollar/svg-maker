OPENAI_API_KEY=your_api_key_here
# Optional (rare): custom API base URL (e.g. proxies/self-hosted gateways)
OPENAI_BASE_URL=

# MotionSpec (recommended production path)
# This is the only OpenAI call used by the default pipeline:
# Prompt -> (OpenAI MotionSpec refine) -> deterministic compiler -> AnimationSpec.
# Set to 1 for production (enables the OpenAI call).
# Set to 0 to run fully offline (no OpenAI calls; deterministic only).
OPENAI_ENABLE_MOTION_SPEC=1
# Model used for MotionSpec refinement (when enabled). Leave blank to use the default in code (currently gpt-4o).
OPENAI_MODEL_MOTION_SPEC=gpt-4o

# Optional: allow the model to choose a different template/icon type than the local router.
# This makes the system feel more natural-language-driven and reduces "hardcoded" routing.
OPENAI_MOTION_SPEC_ALLOW_TEMPLATE=1

# Debug logging for OpenAI calls (prints response id + parsed MotionSpec summary)
OPENAI_DEBUG=1

# Legacy / optional: direct full AnimationSpec parsing (not used by the default pipeline).
# Kept for experimentation only.
OPENAI_MODEL_PARSE=
