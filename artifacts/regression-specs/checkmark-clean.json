{
  "id": "success-checkmark-animation",
  "title": "SaaS Completion Success",
  "duration": 1.8,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1920,
    "height": 1080,
    "background": "#F0FFF0"
  },
  "elements": [
    {
      "id": "checkmark",
      "type": "checkmark",
      "layer": "main",
      "x": 860,
      "y": 440,
      "width": 200,
      "height": 200,
      "viewBoxWidth": 100,
      "viewBoxHeight": 100,
      "stroke": "#22C55E",
      "strokeWidth": 5,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 1.2,
          "property": "draw",
          "from": 0,
          "to": 100,
          "easing": "linear"
        },
        {
          "start": 1.2,
          "end": 1.8,
          "property": "scale",
          "from": 1,
          "to": 1.1,
          "easing": "spring"
        }
      ]
    },
    {
      "id": "checkmark-ring",
      "type": "ring",
      "layer": "background",
      "x": 860,
      "y": 440,
      "width": 200,
      "height": 200,
      "stroke": "#22C55E",
      "strokeWidth": 3,
      "opacity": 0.08,
      "animations": [
        {
          "start": 0,
          "end": 0.48,
          "property": "draw",
          "from": 0,
          "to": 1,
          "easing": "easeInOut"
        },
        {
          "start": 0,
          "end": 0.22,
          "property": "opacity",
          "from": 0,
          "to": 0.18,
          "easing": "easeOut"
        },
        {
          "start": 0.22,
          "end": 0.85,
          "property": "opacity",
          "from": 0.18,
          "to": 0.08,
          "easing": "easeInOut"
        }
      ]
    }
  ]
}