{
  "id": "heart_animation_001",
  "title": "Bold Red Heart Animation",
  "duration": 2.4,
  "fps": 30,
  "loop": true,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#FFFDD0"
  },
  "elements": [
    {
      "id": "heart_main",
      "type": "heart",
      "layer": "main",
      "x": 390,
      "y": 390,
      "width": 300,
      "height": 300,
      "viewBoxWidth": 24,
      "viewBoxHeight": 24,
      "fill": "#FF0000",
      "opacity": 1,
      "offsetX": -4,
      "offsetY": -8,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 1.2,
          "property": "scale",
          "from": 1,
          "to": 1.2,
          "easing": "easeOut"
        },
        {
          "start": 1.2,
          "end": 2.4,
          "property": "scale",
          "from": 1.2,
          "to": 1,
          "easing": "easeIn"
        }
      ]
    },
    {
      "id": "heart_main-ring",
      "type": "ring",
      "layer": "background",
      "x": 390,
      "y": 390,
      "width": 300,
      "height": 300,
      "stroke": "#FF2D55",
      "strokeWidth": 3,
      "opacity": 0.16,
      "animations": [
        {
          "start": 0,
          "end": 0.2,
          "property": "scale",
          "from": 0.92,
          "to": 1.26,
          "easing": "easeOut"
        },
        {
          "start": 0,
          "end": 0.55,
          "property": "opacity",
          "from": 0.16,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}