{
  "id": "payment-cashflow-animation",
  "title": "Payment Cashflow Animation",
  "duration": 3,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#001F3F"
  },
  "elements": [
    {
      "id": "wallet1",
      "type": "wallet",
      "layer": "main",
      "x": 490,
      "y": 490,
      "width": 230,
      "height": 230,
      "viewBoxWidth": 1024,
      "viewBoxHeight": 1024,
      "stroke": "#FF2D55",
      "strokeWidth": 6,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 1.5,
          "property": "scale",
          "from": 1,
          "to": 1.2,
          "easing": "easeOut"
        },
        {
          "start": 1.5,
          "end": 3,
          "property": "scale",
          "from": 1.2,
          "to": 1,
          "easing": "easeIn"
        }
      ]
    },
    {
      "id": "wallet1-ring",
      "type": "ring",
      "layer": "background",
      "x": 490,
      "y": 490,
      "width": 230,
      "height": 230,
      "stroke": "#FF2D55",
      "strokeWidth": 2,
      "opacity": 0.12,
      "animations": [
        {
          "start": 0.05,
          "end": 0.3,
          "property": "scale",
          "from": 0.9,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0.05,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}