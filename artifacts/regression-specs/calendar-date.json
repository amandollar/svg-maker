{
  "id": "calendar-event-countdown",
  "title": "Event Countdown Animation",
  "duration": 2.1,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#001F3F"
  },
  "elements": [
    {
      "id": "calendar1",
      "type": "calendar",
      "layer": "main",
      "x": 450,
      "y": 450,
      "width": 210,
      "height": 210,
      "viewBoxWidth": 24,
      "viewBoxHeight": 24,
      "stroke": "#FF2D55",
      "strokeWidth": 6,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 2.1,
          "property": "scale",
          "from": 1,
          "to": 1.2,
          "easing": "easeOut"
        },
        {
          "start": 0,
          "end": 2.1,
          "property": "opacity",
          "from": 1,
          "to": 0.8,
          "easing": "easeIn"
        }
      ]
    },
    {
      "id": "calendar1-ring",
      "type": "ring",
      "layer": "background",
      "x": 450,
      "y": 450,
      "width": 210,
      "height": 210,
      "stroke": "#FF2D55",
      "strokeWidth": 2,
      "opacity": 0.12,
      "animations": [
        {
          "start": 0.05,
          "end": 0.3,
          "property": "scale",
          "from": 0.9,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0.05,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}