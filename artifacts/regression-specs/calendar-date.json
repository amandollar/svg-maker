{
  "id": "calendar_event_countdown",
  "title": "Calendar Event Countdown Animation",
  "duration": 2.1,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#001F3F"
  },
  "elements": [
    {
      "id": "calendar1",
      "type": "calendar",
      "layer": "main",
      "x": 440,
      "y": 440,
      "width": 210,
      "height": 210,
      "viewBoxWidth": 100,
      "viewBoxHeight": 100,
      "stroke": "#FFFFFF",
      "strokeWidth": 2,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": true,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 2.1,
          "property": "scale",
          "from": 1.2,
          "to": 1,
          "easing": "easeInOut"
        },
        {
          "start": 0,
          "end": 2.1,
          "property": "opacity",
          "from": 0,
          "to": 1,
          "easing": "easeOut"
        }
      ]
    },
    {
      "id": "calendar1-ring",
      "type": "ring",
      "layer": "background",
      "x": 440,
      "y": 440,
      "width": 210,
      "height": 210,
      "stroke": "#FFFFFF",
      "strokeWidth": 2,
      "opacity": 0.12,
      "animations": [
        {
          "start": 0.05,
          "end": 0.3,
          "property": "scale",
          "from": 0.9,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0.05,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}