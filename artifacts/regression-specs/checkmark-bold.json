{
  "id": "fintech-approval-checkmark",
  "title": "Fintech Approval Checkmark",
  "duration": 1.8,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1920,
    "height": 1080,
    "background": "#FFFFFF"
  },
  "elements": [
    {
      "id": "checkmark1",
      "type": "checkmark",
      "layer": "main",
      "x": 860,
      "y": 440,
      "width": 200,
      "height": 200,
      "viewBoxWidth": 800,
      "viewBoxHeight": 800,
      "stroke": "#3B82F6",
      "strokeWidth": 5,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowColor": "#0000FF",
      "glowStrength": 8,
      "shadowColor": "#0000FF",
      "shadowBlur": 15,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 1.6,
          "property": "scale",
          "from": 0,
          "to": 1.15,
          "easing": "elastic"
        },
        {
          "start": 1.6,
          "end": 1.8,
          "property": "scale",
          "from": 1.15,
          "to": 1,
          "easing": "snapUp"
        }
      ]
    },
    {
      "id": "checkmark1-ring",
      "type": "ring",
      "layer": "background",
      "x": 860,
      "y": 440,
      "width": 200,
      "height": 200,
      "stroke": "#3B82F6",
      "strokeWidth": 4,
      "opacity": 0.18,
      "animations": [
        {
          "start": 0,
          "end": 0.48,
          "property": "draw",
          "from": 0,
          "to": 1,
          "easing": "easeInOut"
        },
        {
          "start": 0,
          "end": 0.22,
          "property": "opacity",
          "from": 0,
          "to": 0.32,
          "easing": "easeOut"
        },
        {
          "start": 0.22,
          "end": 0.85,
          "property": "opacity",
          "from": 0.32,
          "to": 0.18,
          "easing": "easeInOut"
        }
      ]
    }
  ]
}