{
  "id": "camera-brand-animation",
  "title": "Camera Brand Animation",
  "duration": 3,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#000000"
  },
  "elements": [
    {
      "id": "camera-icon",
      "type": "camera",
      "layer": "main",
      "x": 440,
      "y": 440,
      "width": 250,
      "height": 250,
      "viewBoxWidth": 100,
      "viewBoxHeight": 100,
      "stroke": "#FF2D55",
      "strokeWidth": 6,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 1.5,
          "property": "scale",
          "from": 0.5,
          "to": 1.2,
          "easing": "snapUp"
        },
        {
          "start": 1.5,
          "end": 3,
          "property": "scale",
          "from": 1.2,
          "to": 1,
          "easing": "easeOut"
        }
      ]
    },
    {
      "id": "camera-icon-ring",
      "type": "ring",
      "layer": "background",
      "x": 440,
      "y": 440,
      "width": 250,
      "height": 250,
      "stroke": "#FF2D55",
      "strokeWidth": 2,
      "opacity": 0.12,
      "animations": [
        {
          "start": 0.05,
          "end": 0.3,
          "property": "scale",
          "from": 0.9,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0.05,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}