{
  "id": "business-report-animation",
  "title": "Business Report Animation",
  "duration": 3,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#1a1a1a"
  },
  "elements": [
    {
      "id": "main-pie",
      "type": "pie",
      "layer": "main",
      "x": 440,
      "y": 440,
      "width": 220,
      "height": 220,
      "viewBoxWidth": 100,
      "viewBoxHeight": 100,
      "fill": "#ffffff",
      "stroke": "#ff6347",
      "strokeWidth": 5,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0.5,
          "end": 3,
          "property": "draw",
          "from": 0,
          "to": 1,
          "easing": "easeInOut"
        }
      ]
    },
    {
      "id": "main-pie-ring",
      "type": "ring",
      "layer": "background",
      "x": 440,
      "y": 440,
      "width": 220,
      "height": 220,
      "stroke": "#ff6347",
      "strokeWidth": 2,
      "opacity": 0.12,
      "animations": [
        {
          "start": 0.05,
          "end": 0.3,
          "property": "scale",
          "from": 0.9,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0.05,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}