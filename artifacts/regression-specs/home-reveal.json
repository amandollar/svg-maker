{
  "id": "real_estate_animation",
  "title": "Real Estate Reveal",
  "duration": 2,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1920,
    "height": 1080,
    "background": "#1A1A1A"
  },
  "elements": [
    {
      "id": "home_icon",
      "type": "home",
      "layer": "main",
      "x": 860,
      "y": 440,
      "width": 220,
      "height": 220,
      "viewBoxWidth": 104,
      "viewBoxHeight": 96,
      "stroke": "#FF2D55",
      "strokeWidth": 6,
      "opacity": 0,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 1,
          "property": "opacity",
          "from": 0,
          "to": 1,
          "easing": "easeInOut"
        },
        {
          "start": 1,
          "end": 2,
          "property": "translateY",
          "from": 20,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    },
    {
      "id": "home_icon-ring",
      "type": "ring",
      "layer": "background",
      "x": 860,
      "y": 440,
      "width": 220,
      "height": 220,
      "stroke": "#FF2D55",
      "strokeWidth": 2,
      "opacity": 0.12,
      "animations": [
        {
          "start": 0.05,
          "end": 0.3,
          "property": "scale",
          "from": 0.9,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0.05,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}