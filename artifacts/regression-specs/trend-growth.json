{
  "id": "stock-growth-animation",
  "title": "Stock Growth Animation",
  "duration": 2.8,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#202020"
  },
  "elements": [
    {
      "id": "trend-line",
      "type": "trend",
      "layer": "main",
      "x": 190,
      "y": 190,
      "width": 700,
      "height": 700,
      "viewBoxWidth": 700,
      "viewBoxHeight": 700,
      "stroke": "#FF2D55",
      "strokeWidth": 3,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 2.8,
          "property": "draw",
          "from": 0,
          "to": 1,
          "easing": "easeInOut"
        }
      ]
    },
    {
      "id": "trend-line-ring",
      "type": "ring",
      "layer": "background",
      "x": 190,
      "y": 190,
      "width": 700,
      "height": 700,
      "stroke": "#FF2D55",
      "strokeWidth": 2,
      "opacity": 0.12,
      "animations": [
        {
          "start": 0.05,
          "end": 0.3,
          "property": "scale",
          "from": 0.9,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0.05,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}