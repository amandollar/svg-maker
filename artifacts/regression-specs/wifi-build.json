{
  "id": "connectivity_build",
  "title": "Wifi Connectivity Animation",
  "duration": 2.2,
  "fps": 30,
  "loop": true,
  "canvas": {
    "width": 1080,
    "height": 1080,
    "background": "#000000"
  },
  "elements": [
    {
      "id": "wifi_signal",
      "type": "wifi",
      "layer": "main",
      "x": 490,
      "y": 490,
      "width": 200,
      "height": 200,
      "viewBoxWidth": 24,
      "viewBoxHeight": 24,
      "stroke": "#FF2D55",
      "strokeWidth": 6,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 1.1,
          "property": "scale",
          "from": 0.5,
          "to": 1.5,
          "easing": "easeOut"
        },
        {
          "start": 1.1,
          "end": 2.2,
          "property": "scale",
          "from": 1.5,
          "to": 0.5,
          "easing": "easeIn"
        }
      ]
    },
    {
      "id": "wifi_signal-glow",
      "type": "glow",
      "layer": "background",
      "x": 466,
      "y": 466,
      "width": 248,
      "height": 248,
      "fill": "#FF2D55",
      "opacity": 0.12,
      "animations": [
        {
          "start": 0,
          "end": 0.35,
          "property": "scale",
          "from": 0.95,
          "to": 1.12,
          "easing": "easeOut"
        },
        {
          "start": 0,
          "end": 0.7,
          "property": "opacity",
          "from": 0.12,
          "to": 0.02,
          "easing": "easeOut"
        }
      ]
    }
  ]
}