{
  "id": "video-intro-reveal",
  "title": "Play Button Reveal",
  "duration": 2,
  "fps": 30,
  "loop": false,
  "canvas": {
    "width": 1920,
    "height": 1080,
    "background": "#14213d"
  },
  "elements": [
    {
      "id": "play-button",
      "type": "play",
      "layer": "main",
      "x": 860,
      "y": 440,
      "width": 200,
      "height": 200,
      "viewBoxWidth": 24,
      "viewBoxHeight": 24,
      "fill": "#ffffff",
      "stroke": "#FF2D55",
      "strokeWidth": 6,
      "opacity": 1,
      "offsetX": 0,
      "offsetY": 0,
      "glowStrength": 0,
      "shadowBlur": 0,
      "trail": false,
      "flash": false,
      "ripple": false,
      "animations": [
        {
          "start": 0,
          "end": 0.5,
          "property": "scale",
          "from": 0,
          "to": 1,
          "easing": "easeOut"
        },
        {
          "start": 0.5,
          "end": 2,
          "property": "opacity",
          "from": 0,
          "to": 1,
          "easing": "easeInOut"
        }
      ]
    },
    {
      "id": "play-button-ring",
      "type": "ring",
      "layer": "background",
      "x": 860,
      "y": 440,
      "width": 200,
      "height": 200,
      "stroke": "#FF2D55",
      "strokeWidth": 3,
      "opacity": 0.14,
      "animations": [
        {
          "start": 0,
          "end": 0.25,
          "property": "scale",
          "from": 0.92,
          "to": 1.18,
          "easing": "easeOut"
        },
        {
          "start": 0,
          "end": 0.6,
          "property": "opacity",
          "from": 0.14,
          "to": 0,
          "easing": "easeOut"
        }
      ]
    }
  ]
}